# ============================================================
# EMBASSY SYSTEM — Environment Variables
# Copie este arquivo para .env e preencha os valores
# ============================================================

# ---- Banco de dados (VPS) ----
DB_HOST=your-vps-ip-or-hostname
DB_PORT=5432
DB_NAME=embassy_db
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# ---- JWT ----
JWT_SECRET=troque_por_uma_string_longa_e_aleatoria_aqui_min_32_chars
JWT_EXPIRES_IN=8h

# ---- Servidor ----
PORT=3001
NODE_ENV=development

# ---- CORS / Frontend ----
# Em desenvolvimento: http://localhost:5173
# Em produção: https://seu-dominio.com
FRONTEND_URL=http://localhost:5173
