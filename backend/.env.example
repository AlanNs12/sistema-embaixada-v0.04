# =============================================================
# EMBASSY SYSTEM — VARIÁVEIS DE AMBIENTE BACKEND
# 1. Copie: cp .env.example .env
# 2. Preencha com seus valores reais
# 3. NUNCA commite o .env no git (já está no .gitignore)
# =============================================================

# ----------------------------------------------------------------
# BANCO DE DADOS (PostgreSQL na VPS)
# ----------------------------------------------------------------
DB_HOST=SEU_IP_OU_HOSTNAME_VPS
DB_PORT=5432
DB_NAME=embassy_db
DB_USER=seu_usuario_db
DB_PASSWORD=sua_senha_db

# ----------------------------------------------------------------
# AUTENTICAÇÃO JWT
# Gere uma chave forte: openssl rand -hex 32
# ----------------------------------------------------------------
JWT_SECRET=substitua_por_string_aleatoria_longa_minimo_32_caracteres
JWT_EXPIRES_IN=8h

# ----------------------------------------------------------------
# SERVIDOR BACKEND
# BACKEND_HOST: interface onde o Express escuta
#   - 0.0.0.0  → aceita de qualquer interface (usar em produção com Nginx)
#   - 127.0.0.1 → só aceita localmente (mais seguro se Nginx estiver no mesmo servidor)
# BACKEND_PORT: porta do Express (Nginx faz proxy para ela)
# ----------------------------------------------------------------
BACKEND_HOST=127.0.0.1
BACKEND_PORT=3001
NODE_ENV=production

# ----------------------------------------------------------------
# URLs PÚBLICAS DA APLICAÇÃO
# APP_PUBLIC_URL: URL completa do sistema (como o usuário acessa no navegador)
#   Exemplos: http://192.168.1.100  |  https://embaixada.gov.br
# FRONTEND_URL: usada no CORS do backend (mesma que APP_PUBLIC_URL)
# ----------------------------------------------------------------
APP_PUBLIC_URL=http://SEU_IP_PUBLICO
FRONTEND_URL=http://SEU_IP_PUBLICO

# ----------------------------------------------------------------
# NGINX (usado pelo script setup.sh para gerar a configuração)
# NGINX_PORT: porta HTTP pública (normalmente 80)
# NGINX_SERVER_NAME: domínio ou IP público que o Nginx vai responder
#   Use _ para responder a qualquer hostname/IP
# ----------------------------------------------------------------
NGINX_PORT=80
NGINX_SERVER_NAME=_
