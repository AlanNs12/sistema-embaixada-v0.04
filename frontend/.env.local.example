# =============================================================
# EMBASSY SYSTEM — VARIÁVEIS DO FRONTEND
# Copie este arquivo para .env.local e ajuste
# NUNCA commite .env.local no git
# =============================================================

# ---- URL da API backend ----
# Desenvolvimento local:
VITE_API_URL=http://localhost:3001/api

# Produção (comente a linha acima e descomente a abaixo):
# VITE_API_URL=http://SEU_IP_SERVIDOR/api
# ou com domínio:
# VITE_API_URL=https://seu-dominio.com/api

# ---- Porta do backend (usada pelo proxy do Vite em desenvolvimento) ----
# Deve ser a mesma que PORT no backend/.env
VITE_BACKEND_PORT=3001

# ---- Endereço do backend para o proxy do Vite (apenas desenvolvimento) ----
# Em produção o Nginx faz o proxy, então esta variável só importa localmente
VITE_BACKEND_HOST=localhost
