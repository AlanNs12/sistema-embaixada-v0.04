# =============================================================
# EMBASSY SYSTEM — VARIÁVEIS DE AMBIENTE FRONTEND
# 1. Copie: cp .env.example .env.local
# 2. Preencha com seus valores reais
# 3. NUNCA commite o .env.local no git
#
# IMPORTANTE: todas as variáveis do Vite DEVEM começar com VITE_
# =============================================================

# ----------------------------------------------------------------
# URL DA API BACKEND
# Desenvolvimento: http://localhost:3001/api
# Produção (mesmo servidor com Nginx): /api
# Produção (servidor separado): http://IP_DO_BACKEND/api
# ----------------------------------------------------------------
VITE_API_URL=http://localhost:3001/api

# ----------------------------------------------------------------
# AMBIENTE (informativo, usado em logs)
# ----------------------------------------------------------------
VITE_APP_ENV=development
